<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitHub Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body { height: 100%; }
        body { display: flex; flex-direction: column; min-height: 100vh; }
        main { flex: 1 0 auto; }
        footer { flex-shrink: 0; }
    </style>
</head>
<body class="bg-dark">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark" style="background: linear-gradient(90deg, #0d0d0d 0%, #1a1a2e 100%); border-bottom: 2px solid #ffc107;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" style="font-family: 'Teko', sans-serif; letter-spacing: 2px;">
                    <i class="bi bi-gear-fill text-warning me-2"></i>FitHub Admin
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="Admin" asp-controller="Gym" asp-action="Index">
                                <i class="bi bi-building me-1"></i>Salonlar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="Admin" asp-controller="Service" asp-action="Index">
                                <i class="bi bi-stars me-1"></i>Hizmetler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="Admin" asp-controller="Trainer" asp-action="Index">
                                <i class="bi bi-person-badge me-1"></i>Antrenörler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="Admin" asp-controller="Appointment" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i>Randevular
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-box-arrow-left me-1"></i>Siteye Dön
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="pb-5">
        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </main>

    <footer class="py-4 mt-auto" style="background: linear-gradient(90deg, #0d0d0d 0%, #1a1a2e 100%); border-top: 2px solid #ffc107;">
        <div class="container text-center">
            <span class="text-muted">&copy; @DateTime.Now.Year - FitHub Admin Panel</span>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
